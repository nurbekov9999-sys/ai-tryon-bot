# === Telegram ===
TELEGRAM_BOT_TOKEN=

# === NanoBanana AI (image generation) ===
NANOBANANA_API_KEY=
NANOBANANA_API_ENDPOINT=https://api.nanobananaapi.ai/api/v1/nanobanana/generate-2
NANOBANANA_TASK_ENDPOINT=https://api.nanobananaapi.ai/api/v1/nanobanana/record-info
NANOBANANA_ASPECT_RATIO=auto
NANOBANANA_RESOLUTION=1K
NANOBANANA_MAX_WAIT_SECONDS=300
NANOBANANA_POLL_INTERVAL_SECONDS=4
NANOBANANA_STYLE_REFS_COUNT=3

# === Reference upload ===
REF_UPLOAD_HOST_ORDER=catbox,0x0
REF_UPLOAD_CONCURRENCY=3
REF_UPLOAD_VERIFY_URLS=true

# === Manager (receives lead notifications) ===
MANAGER_TELEGRAM_USERNAME=your_username
MANAGER_CHAT_ID=

# === CRM Integration (optional) ===
